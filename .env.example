# ──────────────────────────────────────────────────────────────────────────
# .env.example
#
# Template for the real .env file. Copy this to .env and fill in your own
# values — .env is gitignored so your actual credentials never get
# committed:
#
#   cp .env.example .env
#
# Environment variables consumed by docker-compose.yml.
# ──────────────────────────────────────────────────────────────────────────

# ── Postgres ────────────────────────────────────────────────────────────
# Plain credentials for the wallet database. ACA-Py uses the SAME values
# below (via --wallet-storage-creds in docker-compose.yml) to log into
# Postgres and store its wallet records there.
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ssi_wallet_db

# ── ACA-Py (did-agent) ──────────────────────────────────────────────────

# Friendly name for the agent. Shown to other agents during a DIDComm
# connection handshake (e.g. "Alice wants to connect" → this is "Alice").
ACAPY_LABEL=My SSI Agent

# How chatty the agent's logs are. Useful values: DEBUG, INFO, WARNING, ERROR.
# DEBUG is great while learning since you see every protocol step.
ACAPY_LOG_LEVEL=INFO

# The name and encryption key for the agent's wallet (its "keychain").
# WALLET_NAME just labels the wallet; WALLET_KEY encrypts its contents.
# Use a long random string for WALLET_KEY — this is what protects the
# wallet's contents at rest.
ACAPY_WALLET_NAME=my_ssi_wallet
ACAPY_WALLET_KEY=changeme

# Protects the admin API (port 8021) with a static API key. Every request
# to the admin API must include header: X-Api-Key: <this value>
# Without this, anyone who can reach port 8021 could control your agent.
ACAPY_ADMIN_API_KEY=changeme

# The address ACA-Py tells OTHER agents to send DIDComm messages back to.
# Inside this docker-compose stack, "did-agent" resolves to this
# container, so http://did-agent:8020 works for agents running in the
# SAME compose project (e.g. a second agent you add later for testing).
#
# This will NOT be reachable from a real agent running somewhere else on
# the internet — for that you'd need a public hostname or a tool like
# ngrok pointed at port 8020, and you'd set ACAPY_ENDPOINT to that public
# URL instead. Fine to leave as-is while you're just exploring locally.
ACAPY_ENDPOINT=http://did-agent:8020

# Host ports. Change these if something else on your machine already
# uses 8020/8021 (the values after the colon in docker-compose.yml stay
# fixed — only the host-side number changes).
ACAPY_INBOUND_PORT=8020
ACAPY_ADMIN_PORT=8021

# ── webhook-receiver ─────────────────────────────────────────────────────
# Port the dashboard listens on, both inside its container and on your
# host machine.
WEBHOOK_PORT=3001
